{% set postsCount = collections.posts_en | length %}
{% set latestPostsCount = postsCount | min(numberOfLatestPostsToShow) %}

<p>Hello! I'm <a href="./about/">Andrea</a> and I wrote...</p>

{# <h1>Latest {{ latestPostsCount }} Post{% if latestPostsCount != 1 %}s{% endif %}</h1> #}

{% set postslist = collections.posts_en | head(-1 * numberOfLatestPostsToShow) %}
{% set postslistCounter = postsCount %}
{% include "postslist.njk" %}

{% set morePosts = postsCount - numberOfLatestPostsToShow %}
{% if morePosts > 0 %}
<p>{{ morePosts }} more post{% if morePosts != 1 %}s{% endif %} can be found in <a href="{{ '/blog/' | locale_url }}">the archive</a>.</p>
{% endif %}
