---
layout: layouts/base.njk
---
{# Only include the syntax highlighter CSS on blog posts #}
{%- css %}@layer syntax-highlighting { {% include "node_modules/prismjs/themes/prism-okaidia.css" %} }{% endcss %}
{#- {%- css %}{% include "public/css/prism-diff.css" %}{%- endcss %} -#}
<nav class="post-back post-back--top">
  <a href="{{ '/' | locale_url }}">&larr; {{ strings[page.lang or "en"].backToHome }}</a>
</nav>
<h1>{{ title }}</h1>

<ul class="post-metadata">
	<li><time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time></li>
	{%- for tag in tags | filterTagList %}
	{%- set tagUrl %}{{ ("/tags/" + (tag | slugify) + "/") | locale_url }}{% endset %}
	<li><a href="{{ tagUrl }}" class="post-tag">{{ tag }}</a>{%- if not loop.last %}, {% endif %}</li>
	{%- endfor %}
</ul>

{{ content | safe }}

{%- set postsCollection = collections["posts_" + (page.lang or "en")] %}
{%- if postsCollection %}
{%- set previousPost = postsCollection | getPreviousCollectionItem %}
{%- set nextPost = postsCollection | getNextCollectionItem %}
{%- if nextPost or previousPost %}
<ul class="links-nextprev">
	{%- if previousPost %}<li>{{ strings[page.lang or "en"].previous }}: <a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a></li>{% endif %}
	{%- if nextPost %}<li>{{ strings[page.lang or "en"].next }}: <a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a></li>{% endif %}
</ul>
{%- endif %}
{%- endif %}
